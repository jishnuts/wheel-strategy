# Alpaca credentials
# Copy this file to .env and fill in your keys.
# Get paper-trading keys from: https://app.alpaca.markets -> Paper Account -> API Keys

ALPACA_API_KEY=PASTE_YOUR_PAPER_API_KEY_HERE
ALPACA_SECRET_KEY=PASTE_YOUR_PAPER_SECRET_KEY_HERE

# Email notifications (optional)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
GMAIL_TO=you@gmail.com

# Notes
# PAPER_MODE = True is set in src/config.py (default).
# To go live: replace keys above with LIVE keys and set PAPER_MODE = False in src/config.py
